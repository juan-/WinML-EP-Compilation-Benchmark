            <!-- Tab 3: Glossary -->
            <PivotItem Header="Glossary">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                    <StackPanel Spacing="20" MaxWidth="900">

                        <!-- Intro -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Glossary" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                Text="Definitions for the concepts and benchmark columns used throughout the app. Start with Core Concepts, then jump to the section for whichever scenario tab you're using." />
                        </StackPanel>

                        <!-- Core Concepts -->
                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Core Concepts" FontSize="18" FontWeight="SemiBold" />

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Execution Provider (EP)" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="The hardware backend ONNX Runtime uses to execute model operations. Examples: CPUExecutionProvider (CPU), DmlExecutionProvider (GPU via DirectML), OpenVINOExecutionProvider (Intel CPU/GPU/NPU), QNNExecutionProvider (Qualcomm NPU). Each EP optimizes inference for its target hardware." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Compilation Mode" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="Each model is benchmarked along two compilation paths per EP. JIT: model loaded as-is — vendor EPs compile the graph during InferenceSession construction (that cost shows up under Session Creation). AOT: model pre-compiled for that EP via OrtModelCompilationOptions and persisted as a *_ctx.onnx artifact — the upfront cost is paid once, then skipped on every subsequent load. On the CPU EP there is no codegen — AOT just persists ORT's graph optimizations." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Cold vs Warm Runs" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="Each EP is benchmarked in four rows: 'JIT (Cold)' and 'AOT (Cold)' do the actual compilation work — JIT during session creation, AOT via OrtModelCompilationOptions — then run inference once. 'Warm (JIT-built)' and 'Warm (AOT-built)' reuse the cached InferenceSession from the matching cold run; no compilation or session construction occurs — just session.Run() against the already-built artifact. The 'JIT-built' / 'AOT-built' suffix on warm rows describes which lineage produced the cached session, not work happening at runtime. Cold rows show first-time-use cost a user would pay; Warm rows show steady-state inference performance, which is the better number for comparing EPs against each other. The Memory Δ column tells the same story: Cold rows show how much memory the model added when loaded; Warm rows show only per-call tensor churn (usually near zero). 'Compare All EPs' clears the session cache before running so every EP gets an honest cold/warm pair." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Heat Map" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="Color emojis on Inference and EP Total columns rank rows from fastest (🟢) to slowest (🔴) based on the current results. ❌ marks rows where a run errored out — these are always sorted to the bottom." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Sorting" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="Click any column header to sort ascending/descending. Default sort is EP Total, fastest first. The # column always reflects the current sort order." />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Shared Benchmark Columns -->
                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Shared Benchmark Columns" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                                    Text="These columns appear in both Image Classification and Text Similarity tabs." />

                                <StackPanel Spacing="2">
                                    <TextBlock Text="#" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="Row number based on the current sort order. Errors are always pinned to the bottom." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Execution Provider" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="The EP used for this row. See Core Concepts above." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Mode" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="One of four values: 'JIT (Cold)' — first run, vendor EP compiles inside session creation; 'AOT (Cold)' — first run, model precompiled via OrtModelCompilationOptions; 'Warm (JIT-built)' — cached JIT-built session reused, no compilation; 'Warm (AOT-built)' — cached AOT-built session reused, no compilation. See Compilation Mode and Cold vs Warm in Core Concepts above." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Session Creation" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="Time to create or fetch the cached InferenceSession for the EP. First-time creation includes loading the model and initializing the EP runtime; warm rows hit the in-memory cache (~0 ms). Important: on 'JIT (Cold)' rows for vendor (NPU/GPU) EPs, the EP also compiles the graph inside this call — that cost lives here, not in the AOT Compile column." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="AOT Compile" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="Time spent in OrtModelCompilationOptions.CompileModel() (ahead-of-time compile) producing an EP-optimized artifact. Possible values: 'XXX ms' on 'AOT (Cold)' rows where the compile actually ran; 'AOT cached' on 'Warm (AOT-built)' rows where the AOT artifact and session are reused; 'during session creation' on 'JIT (Cold)' rows for vendor (NPU/GPU) EPs — compilation still happens, just folded into Session Creation rather than measured here; 'session cached' on 'Warm (JIT-built)' rows where the cached session is reused but no AOT compile ever ran." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Inference" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="Time to run the model on one input. The core EP-dependent metric — lower is better." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="EP Total" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="Sum of Session Creation + AOT Compile + Inference. The total time the EP itself spends on the model, excluding app-level overhead like image preprocessing or tokenization. The primary metric for ranking EPs and the default sort column. On warm rows Session Creation ≈ 0 and AOT Compile is excluded, so this collapses to just Inference — i.e., steady-state EP performance. On 'JIT (Cold)' rows for vendor EPs the vendor compile cost is captured here via Session Creation, even though the AOT Compile column reads 'during session creation'. Distinct from the 'Total' column, which is end-to-end including preprocessing and post-processing." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Total" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="End-to-end wall-clock time including preprocessing, session creation, AOT compile, inference, and post-processing. Reflects the full user-perceived latency." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Memory Δ" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="Change in the app's working-set memory (in MB) before and after the run. Captures both managed and native allocations — including ONNX Runtime model weights, EP buffers, and intermediate tensors. An asterisk (*) marks rows that are the first run for that EP+Mode — the model is being loaded into memory for the first time, so a large positive delta is expected. Warm rows reuse the cached session and typically show near-zero deltas. AOT rows generally use more memory than JIT rows on GPU/NPU EPs because the EP-specific compiled blob (precompiled kernels, fused ops, hardware-native binaries) is materialized in addition to the original graph." />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Image Classification Specific -->
                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Image Classification — Specific Columns" FontSize="18" FontWeight="SemiBold" />

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Image Preprocessing" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="Time to load, decode, resize to 224×224, convert BGRA→RGB, and apply ImageNet normalization. Always runs on CPU regardless of EP — variations across rows are noise, not EP differences." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Top Prediction" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="The highest-confidence ImageNet class label after softmax (e.g., 'golden retriever'). All EPs should produce the same top prediction for a given image; differences may indicate floating-point precision drift." />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Confidence" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                        Text="Softmax probability of the top prediction, as a percentage. Values near 100% mean the model is confident; below 20% means it's unsure." />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Text Similarity Specific -->
                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Text Similarity — Specific Columns" FontSize="18" FontWeight="SemiBold" />

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Tokenization" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
