<Window
    x:Class="WinMLResNet.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinML EP Benchmarking Sample App">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="WinML EP Benchmarking Sample App"
                   FontSize="28" FontWeight="SemiBold" />

        <!-- Tabs -->
        <Pivot Grid.Row="1" x:Name="MainPivot" SelectionChanged="OnMainPivotSelectionChanged">

            <!-- Tab 1: Classification -->
            <PivotItem Header="Image Classification">
                <ScrollViewer x:Name="ClassificationScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                    <StackPanel Spacing="16">

                        <!-- Tab Description -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="Description" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                Text="Classify an image into one of 1,000 ImageNet categories using ResNet-50 v2, a convolutional neural network. Pick an image and an EP to see the top-5 predictions, or click 'Compare All EPs' to benchmark every execution provider side-by-side." />
                        </StackPanel>

                        <!-- Model Selector -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Selected Model:" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock x:Name="ModelNameText" Text="resnet50-v2-7.onnx" FontSize="13" VerticalAlignment="Center" Opacity="0.8" />
                            <Button x:Name="DownloadModelButton" Content="Download Model" Click="OnDownloadModel" FontSize="12" Padding="8,4" />
                            <Button x:Name="ChangeModelButton" Content="Change Model..." Click="OnChangeModel" FontSize="12" Padding="8,4" />
                        </StackPanel>

                        <!-- Controls Row -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="PickImageButton" Content="Pick an Image" Click="OnPickImage" />
                            <ComboBox x:Name="EpSelector" Width="320"
                                      PlaceholderText="Select Execution Provider"
                                      DisplayMemberPath="DisplayName" />
                            <Button x:Name="ClassifyButton" Content="Classify" Click="OnClassify" IsEnabled="False" />
                            <Button x:Name="RunAllButton" Content="Compare All EPs" Click="OnRunAll" IsEnabled="False" />
                            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                                       FontSize="12" Opacity="0.6" />
                        </StackPanel>

                        <!-- Image Preview + Predictions -->
                        <Grid x:Name="ImagePreviewGrid" ColumnSpacing="24" MinHeight="150">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="Gray"
                                    BorderThickness="1" CornerRadius="8" Padding="4">
                                <Image x:Name="PreviewImage" Stretch="Uniform" />
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Top 5 Predictions"
                                           FontSize="20" FontWeight="SemiBold" />
                                <ItemsControl x:Name="ResultsListView">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnSpacing="12" Padding="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="1" Text="{Binding Score}"
                                                           Foreground="DodgerBlue" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>

                        <!-- EP Performance Comparison -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
                                <TextBlock Text="EP Performance Comparison"
                                           FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button x:Name="ExportButton" Content="Export Results" Click="OnExportCsv" FontSize="12" Padding="8,4" IsEnabled="False" />
                            </StackPanel>

                            <!-- Table Header -->
                            <Grid Padding="12,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="#" FontWeight="SemiBold" FontSize="12" Width="24" />
                                <Button Grid.Column="1" Tag="EpName" Click="OnColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="Header_EpName" Text="Execution Provider" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="2" Tag="Mode" Click="OnColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="Header_Mode" Text="Mode" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="3" Tag="Preprocess" Click="OnColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="Header_Preprocess" Text="Image Preprocessing" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="4" Tag="Session" Click="OnColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="Header_Session" Text="Session Creation" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="5" Tag="Compile" Click="OnColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="Header_Compile" Text="AOT Compile" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="6" Tag="Inference" Click="OnColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="Header_Inference" Text="Inference" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="7" Tag="EpLatency" Click="OnColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="Header_EpLatency" Text="EP Total ▼" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="8" Tag="Total" Click="OnColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="Header_Total" Text="Total" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="9" Tag="Memory" Click="OnColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="Header_Memory" Text="Memory Δ" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="10" Tag="TopPrediction" Click="OnColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="Header_TopPrediction" Text="Top Prediction" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="11" Tag="Confidence" Click="OnColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="Header_Confidence" Text="Confidence" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                            </Grid>

                            <!-- Metrics Rows -->
                            <ListView x:Name="MetricsListView" SelectionMode="None" MaxHeight="600">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="12,2" />
                                        <Setter Property="MinHeight" Value="28" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="12" Opacity="0.5" Width="24" />
                                            <TextBlock Grid.Column="1" Text="{Binding EpName}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                            <TextBlock Grid.Column="2" Text="{Binding Mode}" FontSize="12" />
                                            <TextBlock Grid.Column="3" Text="{Binding PreprocessTime}" FontSize="12" />
                                            <TextBlock Grid.Column="4" Text="{Binding SessionTime}" FontSize="12" />
                                            <TextBlock Grid.Column="5" Text="{Binding CompileTime}" FontSize="12" />
                                            <TextBlock Grid.Column="6" Text="{Binding InferenceTime}" Foreground="DodgerBlue" FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Grid.Column="7" Text="{Binding EpPerfTime}" FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Grid.Column="8" Text="{Binding TotalTime}" FontSize="12" />
                                            <TextBlock Grid.Column="9" Text="{Binding MemoryDelta}" FontSize="12" />
                                            <TextBlock Grid.Column="10" Text="{Binding TopPrediction}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                            <TextBlock Grid.Column="11" Text="{Binding TopConfidence}" Foreground="DodgerBlue" FontSize="12" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <TextBlock FontSize="11" Opacity="0.6" Margin="4,4,0,0"
                                Text="* Memory Δ marked with an asterisk is the first run for that EP+Mode (when the model is loaded into memory) — large positive deltas are expected. Subsequent runs reuse the cached session." />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Tab 2: Text Similarity (Embeddings) -->
            <PivotItem Header="Text Similarity">
                <ScrollViewer x:Name="EmbeddingsScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                    <StackPanel Spacing="16">

                        <!-- Tab Description -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="Description" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                Text="Find the closest match for a query in a coffee-shop knowledge bank using all-MiniLM-L6-v2, a transformer-based text embedding model. The model converts your text into a 384-dim vector and ranks corpus entries by cosine similarity — the technique behind semantic search and RAG." />
                        </StackPanel>

                        <!-- Model Selector -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Selected Model:" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock x:Name="EmbModelNameText" Text="all-MiniLM-L6-v2.onnx (not downloaded)" FontSize="13" VerticalAlignment="Center" Opacity="0.8" />
                            <Button x:Name="EmbDownloadModelButton" Content="Download Model" Click="OnEmbDownloadModel" FontSize="12" Padding="8,4" />
                            <Button x:Name="EmbChangeModelButton" Content="Change Model..." Click="OnEmbChangeModel" FontSize="12" Padding="8,4" />
                        </StackPanel>

                        <!-- Query input + Controls -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Query" FontWeight="SemiBold" FontSize="13" />
                            <TextBox x:Name="QueryTextBox" PlaceholderText="Type a customer request, e.g. 'I'd like a hot oat milk latte with no sugar'"
                                     FontSize="14" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <ComboBox x:Name="EmbEpSelector" Width="320"
                                          PlaceholderText="Select Execution Provider"
                                          DisplayMemberPath="DisplayName" />
                                <Button x:Name="EmbSearchButton" Content="Search" Click="OnEmbSearch" IsEnabled="False" />
                                <Button x:Name="EmbRunAllButton" Content="Compare All EPs" Click="OnEmbRunAll" IsEnabled="False" />
                                <TextBlock x:Name="EmbStatusText" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Top-5 matches + Corpus side panel -->
                        <Grid ColumnSpacing="24" MinHeight="200">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Top-5 Matches -->
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="Top 5 Matches" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="The 5 utterances from the coffee-shop knowledge bank that are most similar in meaning to your query."
                                           FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                                <ItemsControl x:Name="EmbMatchesListView">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnSpacing="12" Padding="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Rank}" FontWeight="SemiBold" Width="20" Opacity="0.6" />
                                                <TextBlock Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="2" Text="{Binding Score}" Foreground="DodgerBlue" FontWeight="SemiBold" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Built-in Corpus -->
                            <StackPanel Grid.Column="1" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Coffee Shop Knowledge Bank" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <Button x:Name="EmbDownloadCorpusButton" Content="Download Corpus" Click="OnEmbDownloadCorpus" FontSize="12" Padding="8,4" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Sample customer utterances a coffee-shop ordering bot might recognize. The query is matched against these via cosine similarity of their embeddings."
                                           FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="6" Padding="8" MaxHeight="180">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="EmbCorpusListView">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontSize="11" Opacity="0.75" TextWrapping="Wrap" Margin="0,2" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- EP Performance Comparison -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
                                <TextBlock Text="EP Performance Comparison"
                                           FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button x:Name="EmbExportButton" Content="Export Results" Click="OnEmbExportCsv" FontSize="12" Padding="8,4" IsEnabled="False" />
                            </StackPanel>

                            <!-- Table Header -->
                            <Grid Padding="12,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="#" FontWeight="SemiBold" FontSize="12" Width="24" />
                                <Button Grid.Column="1" Tag="EpName" Click="OnEmbColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="EmbHeader_EpName" Text="Execution Provider" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="2" Tag="Mode" Click="OnEmbColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="EmbHeader_Mode" Text="Mode" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="3" Tag="Tokenize" Click="OnEmbColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="EmbHeader_Tokenize" Text="Tokenization" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="4" Tag="Session" Click="OnEmbColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="EmbHeader_Session" Text="Session Creation" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="5" Tag="Compile" Click="OnEmbColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="EmbHeader_Compile" Text="AOT Compile" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="6" Tag="Inference" Click="OnEmbColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="EmbHeader_Inference" Text="Inference" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="7" Tag="EpLatency" Click="OnEmbColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="EmbHeader_EpLatency" Text="EP Total ▼" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="8" Tag="Total" Click="OnEmbColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="EmbHeader_Total" Text="Total" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="9" Tag="Memory" Click="OnEmbColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="EmbHeader_Memory" Text="Memory Δ" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="10" Tag="TopMatch" Click="OnEmbColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="EmbHeader_TopMatch" Text="Top Match" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                                <Button Grid.Column="11" Tag="Similarity" Click="OnEmbColumnHeaderClick" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Left">
                                    <TextBlock x:Name="EmbHeader_Similarity" Text="Similarity" FontWeight="SemiBold" FontSize="12" />
                                </Button>
                            </Grid>

                            <!-- Metrics Rows -->
                            <ListView x:Name="EmbMetricsListView" SelectionMode="None" MaxHeight="600">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="12,2" />
                                        <Setter Property="MinHeight" Value="28" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="12" Opacity="0.5" Width="24" />
                                            <TextBlock Grid.Column="1" Text="{Binding EpName}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                            <TextBlock Grid.Column="2" Text="{Binding Mode}" FontSize="12" />
                                            <TextBlock Grid.Column="3" Text="{Binding TokenizeTime}" FontSize="12" />
                                            <TextBlock Grid.Column="4" Text="{Binding SessionTime}" FontSize="12" />
                                            <TextBlock Grid.Column="5" Text="{Binding CompileTime}" FontSize="12" />
                                            <TextBlock Grid.Column="6" Text="{Binding InferenceTime}" Foreground="DodgerBlue" FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Grid.Column="7" Text="{Binding EpPerfTime}" FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Grid.Column="8" Text="{Binding TotalTime}" FontSize="12" />
                                            <TextBlock Grid.Column="9" Text="{Binding MemoryDelta}" FontSize="12" />
                                            <TextBlock Grid.Column="10" Text="{Binding TopMatch}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                            <TextBlock Grid.Column="11" Text="{Binding TopSimilarity}" Foreground="DodgerBlue" FontSize="12" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <TextBlock FontSize="11" Opacity="0.6" Margin="4,4,0,0"
                                Text="* Memory Δ marked with an asterisk is the first run for that EP+Mode (when the model is loaded into memory) — large positive deltas are expected. Subsequent runs reuse the cached session." />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Tab 3: EP Compilation Benchmark -->
            <PivotItem Header="EP Compilation">
                <ScrollViewer x:Name="CompileScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                    <StackPanel Spacing="16">

                        <!-- Tab Description -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="Description" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.85"
                                Text="Measure how long each execution provider takes to ahead-of-time compile a model with OrtModelCompilationOptions.CompileModel(). Choose one or more models (the bundled ones, your own .onnx files, or a whole folder) and the EPs to test, then run the sweep. Every compile runs in an isolated worker process, so a provider that native-crashes (e.g. a GPU/NPU EP with no matching hardware) is reported as 'Crashed' instead of taking down the app." />
                        </StackPanel>

                        <!-- Models -->
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="Models" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button x:Name="CompileAddFileButton" Content="Add .onnx File..." Click="OnCompileAddFile" FontSize="12" Padding="8,4" />
                                <Button x:Name="CompileAddFolderButton" Content="Add Folder..." Click="OnCompileAddFolder" FontSize="12" Padding="8,4" />
                                <Button x:Name="CompileClearModelsButton" Content="Clear" Click="OnCompileClearModels" FontSize="12" Padding="8,4" />
                            </StackPanel>
                            <ItemsControl x:Name="CompileModelsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Include, Mode=TwoWay}" Margin="0,1" MinHeight="0">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Label}" FontSize="13" />
                                                <TextBlock Text="{Binding SizeText}" FontSize="12" Opacity="0.55" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="CompileNoModelsText" Text="No models added yet. Add a .onnx file or a folder above."
                                       FontSize="12" Opacity="0.6" />
                        </StackPanel>

                        <!-- Execution Providers -->
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="Execution Providers" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button x:Name="CompileRefreshEpsButton" Content="Refresh EPs" Click="OnCompileRefreshEps" FontSize="12" Padding="8,4" />
                            </StackPanel>
                            <ItemsControl x:Name="CompileEpList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Include, Mode=TwoWay}" Margin="0,1" MinHeight="0">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="13" />
                                                <TextBlock Text="{Binding Note}" FontSize="12" Opacity="0.55" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Only execution providers that enumerate compatible hardware appear as checkboxes above. The panel below lists every installed provider and why the others aren't selectable."
                                       FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- EP registration diagnostics -->
                        <StackPanel Spacing="4" Margin="0,4,0,0">
